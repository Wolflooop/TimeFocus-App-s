# ── Base de datos MySQL ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_NAME=timefocus_db

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=timefocus_jwt_super_secreto_2025_cambia_esto
JWT_EXPIRES_IN=7d

# ── Servidor ─────────────────────────────────────────────────────
PORT=3000
# Cambia esta IP a la IP local de tu PC (ipconfig / ifconfig)
SERVER_IP=192.168.0.106

# ── Nodemailer (Gmail) ───────────────────────────────────────────
# Usa una "Contraseña de aplicación" de Google, NO tu contraseña normal
# Ve a: https://myaccount.google.com/apppasswords
MAIL_USER=tucorreo@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
MAIL_FROM=TimeFocus <tucorreo@gmail.com>

# ── Google OAuth ─────────────────────────────────────────────────
# Crea credenciales en: https://console.cloud.google.com/
# Tipo: "ID de cliente OAuth 2.0" → Android + Web
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com

# ── Seguridad ────────────────────────────────────────────────────
# Tiempo de vida del código de recuperación (minutos)
RESET_CODE_EXPIRES_MIN=10
