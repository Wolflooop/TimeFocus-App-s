{
  "name": "timefocus-web-frontend",
  "version": "1.0.0",
  "description": "Frontend web TimeFocus - Express + Pug + Tailwind",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently \"nodemon app.js\" \"tailwindcss -i ./src/public/css/app.css -o ./src/public/css/output.css --watch\"",
    "build:css": "tailwindcss -i ./src/public/css/app.css -o ./src/public/css/output.css"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "pug": "^3.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.4.0"
  }
}
