extends ../layouts/app

block page
  .page-header
    a.back-btn(href='/perfil') ←
    h1.page-header__title Notificaciones

  .form-card

    .form-field
      label.form-label Notificaciones generales
      .toggle-row
        span Activar notificaciones del navegador
        label.toggle
          input(type="checkbox" id="notif-general")
          span.toggle__slider

    .form-field
      label.form-label Recordatorios de tareas
      .toggle-row
        span Recordarme cuando una tarea vence hoy
        label.toggle
          input(type="checkbox" id="notif-tareas")
          span.toggle__slider

    .form-field
      label.form-label Recordatorios de estudio
      .toggle-row
        span Recordarme iniciar sesión de estudio
        label.toggle
          input(type="checkbox" id="notif-estudio")
          span.toggle__slider

    .form-field
      label.form-label Hora de recordatorio diario
      input.form-input(type="time" id="hora" name="hora" value="08:00")

    .form-field
      label.form-label Resumen semanal
      .toggle-row
        span Recibir resumen de productividad cada semana
        label.toggle
          input(type="checkbox" id="notif-semanal")
          span.toggle__slider

    .form-field
      label.form-label Sonido al terminar Pomodoro
      .toggle-row
        span Activar sonido al terminar sesión Pomodoro
        label.toggle
          input(type="checkbox" id="notif-sonido")
          span.toggle__slider

    #notif-status(style='font-size:13px;color:#888;min-height:18px;margin-bottom:8px')

    .form-footer
      button.btn-primary(type="button" onclick="guardarNotif()") Guardar cambios →
      a.btn-cancel(href='/perfil') Cancelar

  style.
    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #f5f5f5;
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 15px;
      color: #1a1a2e;
    }
    .toggle {
      position: relative;
      display: inline-block;
      width: 48px;
      height: 26px;
      flex-shrink: 0;
    }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle__slider {
      position: absolute;
      cursor: pointer;
      inset: 0;
      background: #ccc;
      border-radius: 26px;
      transition: 0.3s;
    }
    .toggle__slider:before {
      content: '';
      position: absolute;
      width: 20px;
      height: 20px;
      left: 3px;
      bottom: 3px;
      background: white;
      border-radius: 50%;
      transition: 0.3s;
    }
    .toggle input:checked + .toggle__slider { background: #1976d2; }
    .toggle input:checked + .toggle__slider:before { transform: translateX(22px); }

  script.
    // ── Cargar preferencias guardadas ─────────────────────────────
    const prefs = JSON.parse(localStorage.getItem('tf_notif') || '{}');
    document.getElementById('notif-general').checked  = prefs.general  ?? false;
    document.getElementById('notif-tareas').checked   = prefs.tareas   ?? false;
    document.getElementById('notif-estudio').checked  = prefs.estudio  ?? false;
    document.getElementById('notif-semanal').checked  = prefs.semanal  ?? false;
    document.getElementById('notif-sonido').checked   = prefs.sonido   ?? false;
    if (prefs.hora) document.getElementById('hora').value = prefs.hora;

    // Mostrar estado actual del permiso de notificaciones
    const status = document.getElementById('notif-status');
    const updateStatus = () => {
      if (!('Notification' in window)) {
        status.textContent = '⚠️ Tu navegador no soporta notificaciones.';
      } else if (Notification.permission === 'granted') {
        status.textContent = '✅ Notificaciones del navegador: activadas';
        status.style.color = '#4caf50';
      } else if (Notification.permission === 'denied') {
        status.textContent = '🚫 Notificaciones bloqueadas en el navegador. Actívalas desde la configuración del sitio.';
        status.style.color = '#e53935';
      } else {
        status.textContent = '🔔 Al guardar se solicitará permiso de notificaciones.';
      }
    };
    updateStatus();

    async function guardarNotif() {
      // Solicitar permiso si está activado el toggle general
      if (document.getElementById('notif-general').checked && 'Notification' in window) {
        if (Notification.permission === 'default') {
          await Notification.requestPermission();
        }
        updateStatus();
      }

      // Guardar en localStorage
      localStorage.setItem('tf_notif', JSON.stringify({
        general: document.getElementById('notif-general').checked,
        tareas:  document.getElementById('notif-tareas').checked,
        estudio: document.getElementById('notif-estudio').checked,
        semanal: document.getElementById('notif-semanal').checked,
        sonido:  document.getElementById('notif-sonido').checked,
        hora:    document.getElementById('hora').value,
      }));

      status.textContent = '✅ Preferencias guardadas correctamente';
      status.style.color = '#4caf50';
      setTimeout(() => { window.location.href = '/perfil'; }, 1000);
    }
