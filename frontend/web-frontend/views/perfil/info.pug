extends ../layouts/app

block page
  .page-header
    a.back-btn(href='/perfil') ←
    h1.page-header__title Mi Información

  .form-card

    .form-field
      label.form-label Nombre completo
      input.form-input(type="text" id="nombre" name="nombre" placeholder="Ej. Josue Oloarte" value="Josue Oloarte")

    .form-field
      label.form-label Correo electrónico
      input.form-input(type="email" id="correo" name="correo" placeholder="Ej. josue@email.com")

    .form-field
      label.form-label Carrera
      input.form-input(type="text" id="carrera" name="carrera" placeholder="Ej. Ingeniería en Software")

    .form-field
      label.form-label Semestre
      input.form-input(type="number" id="semestre" name="semestre" placeholder="Ej. 5" min="1" max="12")

    .form-field
      label.form-label Institución
      input.form-input(type="text" id="institucion" name="institucion" placeholder="Ej. UTXJ")

    .form-field
      label.form-label Rol
      input.form-input(type="text" id="rol" name="rol" placeholder="Ej. Desarrollador de Software" value="Desarrollador de Software")

    .form-footer
      button.btn-primary(type="button" onclick="guardarInfo()") Guardar cambios →
      a.btn-cancel(href='/perfil') Cancelar
  
  script.
    function guardarInfo() {
      const nombre      = document.getElementById('nombre').value.trim();
      const correo      = document.getElementById('correo').value.trim();
      const carrera     = document.getElementById('carrera').value.trim();
      const semestre    = document.getElementById('semestre').value;
      const institucion = document.getElementById('institucion').value.trim();
      const rol         = document.getElementById('rol').value.trim();

      if (!nombre || !correo) {
        alert('Por favor completa el nombre y el correo.');
        return;
      }

      alert('Información actualizada correctamente ✅');
      window.location.href = '/perfil';
    }