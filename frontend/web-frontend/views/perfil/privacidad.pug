extends ../layouts/app

block page
  .page-header
    a.back-btn(href='/perfil') ←
    h1.page-header__title Privacidad de Datos

  .form-card

    .form-field
      label.form-label Visibilidad del perfil
      .toggle-row
        span Perfil público
        label.toggle
          input(type="checkbox" id="perfil-publico")
          span.toggle__slider

    .form-field
      label.form-label Compartir estadísticas
      .toggle-row
        span Compartir mis estadísticas de estudio
        label.toggle
          input(type="checkbox" id="compartir-stats")
          span.toggle__slider

    .form-field
      label.form-label Historial de actividad
      .toggle-row
        span Guardar historial de sesiones
        label.toggle
          input(type="checkbox" id="historial" checked)
          span.toggle__slider

    .form-field
      label.form-label Datos de uso
      .toggle-row
        span Enviar datos anónimos para mejorar la app
        label.toggle
          input(type="checkbox" id="datos-uso" checked)
          span.toggle__slider

    .form-field
      label.form-label Zona peligrosa
      .danger-box
        .danger-item
          .danger-item__info
            p.danger-item__title Eliminar historial
            p.danger-item__desc Borra todo tu historial de sesiones y actividad
          button.btn-danger#btn-del-historial(type="button") Eliminar
        .danger-item
          .danger-item__info
            p.danger-item__title Eliminar cuenta
            p.danger-item__desc Elimina permanentemente tu cuenta y todos tus datos
          button.btn-danger#btn-del-cuenta(type="button") Eliminar

    #priv-status(style='font-size:13px;min-height:18px;margin-top:4px')

    .form-footer
      button.btn-primary(type="button" onclick="guardarPrivacidad()") Guardar cambios →
      a.btn-cancel(href='/perfil') Cancelar

  style.
    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #f5f5f5;
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 15px;
      color: #1a1a2e;
    }
    .toggle {
      position: relative;
      display: inline-block;
      width: 48px;
      height: 26px;
      flex-shrink: 0;
    }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle__slider {
      position: absolute;
      cursor: pointer;
      inset: 0;
      background: #ccc;
      border-radius: 26px;
      transition: 0.3s;
    }
    .toggle__slider:before {
      content: '';
      position: absolute;
      width: 20px;
      height: 20px;
      left: 3px;
      bottom: 3px;
      background: white;
      border-radius: 50%;
      transition: 0.3s;
    }
    .toggle input:checked + .toggle__slider { background: #1976d2; }
    .toggle input:checked + .toggle__slider:before { transform: translateX(22px); }
    .danger-box {
      background: #fff5f5;
      border: 1px solid #ffcdd2;
      border-radius: 10px;
      overflow: hidden;
    }
    .danger-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid #ffcdd2;
    }
    .danger-item:last-child { border-bottom: none; }
    .danger-item__title { font-size:15px; font-weight:600; color:#1a1a2e; margin-bottom:4px; }
    .danger-item__desc  { font-size:13px; color:#666; }
    .btn-danger {
      background: transparent;
      color: #e53935;
      border: 1px solid #e53935;
      border-radius: 100px;
      padding: 8px 20px;
      font-size: 14px;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s;
      flex-shrink: 0;
    }
    .btn-danger:hover { background: #e53935; color: white; }
    .btn-danger:disabled { opacity: 0.5; cursor: not-allowed; }

  script.
    const status = document.getElementById('priv-status');

    function setStatus(msg, color) {
      status.textContent = msg;
      status.style.color = color || '#666';
    }

    function guardarPrivacidad() {
      // Solo visual — no hay backend para estas preferencias
      setStatus('✅ Preferencias de privacidad guardadas', '#4caf50');
      setTimeout(() => { window.location.href = '/perfil'; }, 1000);
    }

    // ── Eliminar historial ─────────────────────────────────────────
    document.getElementById('btn-del-historial').addEventListener('click', async () => {
      const ok = confirm('¿Seguro que deseas borrar TODO tu historial de sesiones? Esta acción no se puede deshacer.');
      if (!ok) return;

      const btn = document.getElementById('btn-del-historial');
      btn.disabled = true;
      btn.textContent = 'Eliminando...';
      try {
        const res = await fetch('/api/account/sessions', { method: 'DELETE' });
        const data = await res.json();
        if (res.ok) {
          setStatus('✅ Historial eliminado correctamente', '#4caf50');
          btn.textContent = 'Eliminado';
        } else {
          setStatus('❌ Error: ' + (data.error || 'No se pudo eliminar'), '#e53935');
          btn.disabled = false;
          btn.textContent = 'Eliminar';
        }
      } catch {
        setStatus('❌ Error de conexión', '#e53935');
        btn.disabled = false;
        btn.textContent = 'Eliminar';
      }
    });

    // ── Eliminar cuenta ────────────────────────────────────────────
    document.getElementById('btn-del-cuenta').addEventListener('click', async () => {
      const confirmar = prompt('Escribe ELIMINAR para confirmar que deseas borrar tu cuenta permanentemente:');
      if (confirmar !== 'ELIMINAR') {
        if (confirmar !== null) setStatus('❌ Debes escribir exactamente: ELIMINAR', '#e53935');
        return;
      }

      const btn = document.getElementById('btn-del-cuenta');
      btn.disabled = true;
      btn.textContent = 'Eliminando...';
      try {
        const res = await fetch('/api/account/me', { method: 'DELETE' });
        const data = await res.json();
        if (res.ok) {
          alert('Tu cuenta ha sido eliminada. Hasta pronto 👋');
          window.location.href = '/logout';
        } else {
          setStatus('❌ Error: ' + (data.error || 'No se pudo eliminar la cuenta'), '#e53935');
          btn.disabled = false;
          btn.textContent = 'Eliminar';
        }
      } catch {
        setStatus('❌ Error de conexión', '#e53935');
        btn.disabled = false;
        btn.textContent = 'Eliminar';
      }
    });
