extends ../layouts/app

block page
  .page-header
    h1.page-header__title Temas

  .card
    .empty-state(style='padding:40px;text-align:center')
      .empty-state__icon(style='font-size:48px;margin-bottom:16px') 📚
      h3(style='color:#ccc;margin-bottom:8px') No tienes temas aún
      p(style='color:#888;margin-bottom:24px;font-size:14px') Organiza tus materias para vincularlas con tareas y sesiones de estudio.
      a.btn-primary(href='/temas/nueva') + Crear primer tema

  .fab-container
    a.fab(href='/temas/nueva') + Nuevo Tema
