extends ../layouts/base

block content
  .splash
    .splash__blob.splash__blob--tl
    .splash__blob.splash__blob--br
    .splash__logo-box
      svg.splash__logo-icon(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
        circle(cx="12" cy="12" r="10")
        polyline(points="12 6 12 12 16 14")

    .onboarding
      h2.onboarding__title= slide.titulo
      p.onboarding__desc= slide.descripcion

      .splash__dots
        each dot, i in [0,1,2]
          span.splash__dot(class=i === slide.index ? 'splash__dot--active' : '')

      .onboarding__actions
        a.onboarding__btn-next(href=slide.siguiente) Siguiente →
        a.onboarding__btn-skip(href='/login') Omitir introducción
